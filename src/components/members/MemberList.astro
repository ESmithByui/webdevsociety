---
import { App } from 'octokit';
import fs from 'node:fs';
import MemberCard from './MemberCard.astro';
import type { OrgEvent, MemberUser } from '../../../types';

const GITHUB_APP_ID = 3702060;
const GITHUB_APP_INSTALLATION_ID = 132060529;
const GITHUB_ORG = 'Web-Design-Development-Society';

const app = new App({
  appId: GITHUB_APP_ID,
  privateKey: import.meta.env.GITHUB_APP_TOKEN,
});

const installationOctokit = await app.getInstallationOctokit(
  GITHUB_APP_INSTALLATION_ID,
);

let events: OrgEvent[] = [];
if (!fs.existsSync('./events.json')) {
  const eventsResponse = await installationOctokit.request(
    'GET /orgs/{org}/events',
    {
      org: GITHUB_ORG,
      per_page: 100,
    },
  );

  fs.writeFile(
    './events.json',
    JSON.stringify({ data: eventsResponse.data }),
    'utf8',
    (err) => {
      if (err) {
        console.error(err);
      }
    },
  );

  events = eventsResponse.data;
} else {
  events = JSON.parse(fs.readFileSync('./events.json', 'utf8')).data;
}

let members: MemberUser[] = [];
if (!fs.existsSync('./members.json')) {
  const membersResponse = await installationOctokit.paginate(
    'GET /orgs/{org}/members',
    {
      org: GITHUB_ORG,
      per_page: 20,
    },
  );

  fs.writeFile(
    './members.json',
    JSON.stringify({ data: membersResponse }),
    'utf8',
    (err) => {
      if (err) {
        console.error(err);
      }
    },
  );
}
members = JSON.parse(fs.readFileSync('./members.json', 'utf8')).data;

let users: MemberUser[] = [];
if (!fs.existsSync('./users.json')) {
  for (const member of members) {
    const userResponse = await installationOctokit.request(
      'GET /users/{username}',
      {
        username: member.login,
      },
    );
    users.push({
      ...userResponse.data,
      events: events.reduce((acc, event) => {
        if (
          event.actor.login === member.login &&
          event.type === 'PullRequestEvent' &&
          event.repo.name.startsWith('Web-Design-Development-Society/')
        ) {
          acc++;
        }
        return acc;
      }, 0),
      last_merged_pr_at: events.find(
        (event) =>
          event.type === 'PullRequestEvent' &&
          event.actor.login === member.login &&
          event.repo.name.startsWith('Web-Design-Development-Society/'),
      )?.created_at,
    });
  }
  fs.writeFile(
    './users.json',
    JSON.stringify({ data: users.sort((a, b) => b.events - a.events) }),
    'utf8',
    (err) => {
      if (err) {
        console.error(err);
      }
    },
  );
} else {
  users = JSON.parse(fs.readFileSync('./users.json', 'utf8')).data;
}

// const rateLimit = await app.octokit.request('GET /rate_limit');
// console.log(rateLimit.data.rate);
---

<div class="mx-4">
  <h1 class="text-2xl font-bold">Members</h1>
  <p class="text-lg">Total members: {users.length}</p>
  <ul class="grid tablet:grid-cols-2 gap-2">
    {users.map((user) => <MemberCard member={user} />)}
  </ul>
</div>
